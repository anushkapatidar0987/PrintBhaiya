# PrintKarDoBhaiya Backend Environment Variables
# Copy this file to .env and fill in real values for production

DEBUG=True
SECRET_KEY=django-insecure-pkb-dev-key-change-in-production-!@#$%
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (leave empty for SQLite default)
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# Razorpay (leave empty to use mock mode)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Email via Brevo SMTP (leave empty to use console backend)
EMAIL_HOST=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_PORT=587

# WhatsApp Cloud API (leave empty to use log-only mode)
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
